---
export interface Props {
  symptom: string;
}

const { symptom } = Astro.props;
---
<aside class="failure">
  <p class="failure-label mono">Failure mode — {symptom}</p>
  <slot />
</aside>

<style>
  .failure { margin: 1.4rem 0; padding: 1rem 1.2rem; border-left: 3px solid var(--warn); background: color-mix(in srgb, var(--warn) 10%, transparent); border-radius: 0 8px 8px 0; }
  .failure-label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--warn); margin: 0 0 .4rem; }
</style>
