---
// "Principal's Judgment Call" aside — a decision rule ("reach for X when...;
// stay with Y when..."), not a restatement of the surrounding prose.
---
<aside class="judgment">
  <p class="judgment-label mono">Principal's judgment call</p>
  <slot />
</aside>

<style>
  .judgment { margin: 1.4rem 0; padding: 1rem 1.2rem; border-left: 3px solid var(--accent); background: var(--accent-soft); border-radius: 0 8px 8px 0; }
  .judgment-label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin: 0 0 .4rem; }
</style>
