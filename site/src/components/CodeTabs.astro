---
export interface Tab {
  label: string;
  lang: string;
  code: string;
}

export interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
const groupId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="code-tabs" data-group={groupId}>
  <div class="code-tabs-nav" role="tablist">
    {tabs.map((tab, i) => (
      <button
        type="button"
        role="tab"
        class="code-tab-btn"
        aria-selected={i === 0 ? 'true' : 'false'}
        data-target={`${groupId}-${i}`}
      >
        {tab.label}
      </button>
    ))}
  </div>
  {tabs.map((tab, i) => (
    <pre
      class="code-tab-panel"
      id={`${groupId}-${i}`}
      role="tabpanel"
      hidden={i !== 0}
    ><code class={`language-${tab.lang}`} set:text={tab.code} /></pre>
  ))}
</div>

<style>
  .code-tabs { margin: 1.4rem 0; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .code-tabs-nav { display: flex; gap: 2px; background: var(--border); }
  .code-tab-btn {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: .78rem; padding: .5rem .9rem; border: none; cursor: pointer;
    background: var(--panel); color: var(--muted);
  }
  .code-tab-btn[aria-selected="true"] { color: var(--accent); font-weight: 700; }
  .code-tab-panel { margin: 0; padding: 1rem 1.2rem; background: var(--code-bg); color: var(--code-text); overflow-x: auto; font-size: .85rem; }
</style>

<script>
  // One listener per tab group, scoped by data-group — no external deps.
  document.querySelectorAll<HTMLElement>('.code-tabs').forEach((group) => {
    group.querySelectorAll<HTMLButtonElement>('.code-tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.target;
        group.querySelectorAll<HTMLButtonElement>('.code-tab-btn').forEach((b) => {
          b.setAttribute('aria-selected', String(b === btn));
        });
        group.querySelectorAll<HTMLPreElement>('.code-tab-panel').forEach((panel) => {
          panel.hidden = panel.id !== targetId;
        });
      });
    });
  });
</script>
